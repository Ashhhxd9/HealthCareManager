# Database URL connection string. Supporting local SQLite file or Supabase (PostgreSQL)
DATABASE_URL="file:./dev.db"
# For Supabase PostgreSQL, uncomment and configure:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?schema=public"
JWT_SECRET="clinic_manager_super_secret_key"

# Gemini API Integration (Set value to utilize real API, leave empty or 'mock' for sandbox fallback mode)
GEMINI_API_KEY="mock"

# Google OAuth Configuration (Connects doctor calendar, leave empty for sandbox mock log mode)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/oauth/callback"
GOOGLE_LOGIN_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Email Integration (Leave blank to output emails to local emails_sent.json log file)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="no-reply@clinicmanager.com"
